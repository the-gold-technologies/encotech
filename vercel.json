{
  "rewrites": [
    {
      "source": "/robots.txt",
      "destination": "/api/robots"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/",
      "destination": "/api/render"
    },
    {
      "source": "/:path*",
      "destination": "/api/render"
    }
  ]
}
